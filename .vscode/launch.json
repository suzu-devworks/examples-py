{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "examples",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/examples-py/src/examples/console/command.py",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
    {
      "name": "examples flaskr debugger",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "flaskr",
        "FLASK_DEBUG": "1"
      },
      "args": [
        "run",
        "--debugger",
        "--reload"
      ],
      "jinja": true,
      "autoStartBrowser": false
    },
    {
      "name": "Flask app.py debugger",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_DEBUG": "1"
      },
      "args": [
        "run",
        "--debugger",
        "--reload"
      ],
      "jinja": true,
      "autoStartBrowser": false
    },
  ]
}
