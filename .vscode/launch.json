{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "examples",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/examples-py/src/examples/console/command.py",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
    {
      "name": "Python debugger: current file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      // "args": "${command:pickArgs}"
    },
    {
      "name": "Python debugger: Flask",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "${workspaceFolder}/src/web/examples-flask-started/src/flaskr/__init__.py",
        "FLASK_DEBUG": "1"
      },
      "args": [
        "run",
        "--debugger",
        "--reload"
      ],
      "jinja": true,
      "autoStartBrowser": false
    },
  ]
}
