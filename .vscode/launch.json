{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "examples",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/examples-py/src/examples/console/command.py",
      "console": "integratedTerminal",
      "args": "${command:pickArgs}"
    },
    {
      "name": "examples-flask-started debugger",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "${workspaceFolder}/src/web/examples-flask-started/src/flaskr",
        "FLASK_DEBUG": "1"
      },
      "args": [
        "run",
        "--debugger",
        "--reload",
        "--port",
        "5001"
      ],
      "jinja": true,
      "autoStartBrowser": false
    },
    {
      "name": "examples-flask-media debugger",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "${workspaceFolder}/src/web/examples-flask-media/src/app.py",
        "FLASK_DEBUG": "1"
      },
      "args": [
        "run",
        "--debugger",
        "--reload",
        "--port",
        "5002"
      ],
      "jinja": true,
      "autoStartBrowser": false
    },
    {
      "name": "examples: Flask Blueprints",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "${workspaceFolder}/src/web/examples-flask-started/src/blueprints/__init__.py",
        "FLASK_DEBUG": "1"
      },
      "args": [
        "run",
        "--debugger",
        "--reload"
      ],
      "jinja": true,
      "autoStartBrowser": true
    },
  ]
}
